<!--homePage.wxml-->
<!-- 位置授权引导弹窗（仅在用户拒绝后出现，引导去设置页开启） -->
<view class="location-auth-mask" wx:if="{{showLocationAuthModal}}">
  <view class="location-auth-modal">
    <view class="location-auth-icon">📍</view>
    <view class="location-auth-title">开启位置权限</view>
    <view class="location-auth-desc">授权后可查看附近的宝贝，让您更快找到心仪商品</view>
    <button class="location-auth-btn" bindtap="onGetLocationSuccess">去开启位置权限</button>
    <view class="location-skip-btn" bindtap="onSkipLocation">暂不授权，看全部商品</view>
  </view>
</view>

<scroll-view class="container" scroll-y="true" enable-flex="true">
  <!-- 工具栏 -->
  <view class="tool-box">
    <!-- 定位区域：未授权显示图标，已授权显示小区名 -->
    <view class="location-area" bindtap="goLocationPage">
      <view wx:if="{{!locationAuthorized}}">
        <!-- 未授权：仅显示定位图标，加载中有脉冲动画 -->
        <i class="iconfont icon-dingwei {{locationFlash ? 'dingwei' : ''}}"></i>
      </view>
      <view wx:else class="estate-tag">
        <!-- 已授权：显示小区名，若没找到小区则降级显示完整地址 -->
        <i class="iconfont icon-dingwei estate-icon"></i>
        <text class="estate-name">{{locationText}}</text>
      </view>
    </view>
    <!-- 搜索框 -->
    <view class="search" bindtap="gotoSearch">
      <icon type='search' size="14"></icon>
      <view class="input">{{searchKeyWord}}</view>
      <button type="primary" class="search-button">搜 索</button>
    </view>
  </view>
  <!-- 滚动时出现的搜索图标 -->
  <view
    class="hidden-search"
    hidden="{{scrollTop > 40 ? false: true}}"
    bindtap="gotoSearch"
  >
    <icon type='search' size="16" color="#3CB371"></icon>
  </view>
  <!-- 轮播图 -->
  <view class="banner">
    <swiper
      indicator-dots="true"
      indicator-color="#fff"
      indicator-active-color="#3CB371"
      autoplay="true"
      interval="3500"
      duration="400"
      circular="true">
      <swiper-item wx:for="{{swiperImgs}}" wx:key="_id">
        <image src="{{item.img}}" mode="scaleToFill" data-item="{{item}}" bindtap="bannerClick"></image>
      </swiper-item>
    </swiper>
  </view>
  <!-- 没有用户地理位置相关数据时给出的提示 -->
  <view class="noRelevantData" wx:if="{{!hasRelevantData}}">
    <text>您身边1000米内没有相关商品</text>
    <text>为您推荐以下宝贝</text>
  </view>
  <!-- 商品列表 -->
  <view class="products-container">
    <view
      class="products-item"
      wx:for="{{productsList}}"
      wx:key="index"
      data-item="{{item}}"
      bindtap="toProductsDetail">
      <!-- 图片 -->
      <view class="img-container">
        <image class="img" mode="aspectFill" lazy-load="true" src="{{item.displayImg}}" alt=""></image>
      </view>
      <!-- 描述 -->
      <view class="text-container">
        <view class="products-desc">{{item.desc}}</view>
        <view class="products-price">
          <view>
            <text class="products-current-price">￥{{item.currentPrice}}</text>
            <text class="products-origin-price" wx:if="{{item.originPrice}}">￥{{item.originPrice}}</text>
          </view>
          <view class="heat-container">
            热度：
            <i wx:for="{{item.heatIconList}}" wx:key="*this" class="iconfont icon-ziyuan" style="color: red;"></i>
            <i wx:for="{{item.notHeatIconList}}" wx:key="*this" class="iconfont icon-ziyuan"></i>
          </view>
        </view>
      </view>
    </view>
  </view>
  <view wx:if="{{isLoaded}}">
    <mp-loading show="{{showLoading}}" type="circle"></mp-loading>
    <view class="no-more" wx:if="{{!showLoading}}">
      <i class="iconfont icon-Null-data"></i>
      <text>没有更多啦~</text>
    </view>  
  </view>

  <!-- 操作数据库 -->
  <!-- <view class="uploader">
    <navigator url="../databaseGuide/databaseGuide" open-type="navigate" class="uploader-text">
      <text>前端操作数据库</text>
    </navigator>
  </view> -->
</scroll-view>

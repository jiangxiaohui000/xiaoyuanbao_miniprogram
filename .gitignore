# ===== 依赖包（最大性能杀手）=====
node_modules/
# 云函数各自的依赖也需要忽略
cloudfunctions/**/node_modules/
# miniprogram 构建出的 npm 产物（由开发者工具自动生成，不需要提交）
miniprogram/miniprogram_npm/

# ===== 本地私有配置（不应提交到仓库）=====
# project.private.config.json 包含个人调试条件、本地 appid 等，属于本地状态
project.private.config.json

# ===== 开发工具产物 =====
# 微信开发者工具生成的缓存目录
.DS_Store
**/.DS_Store

# ===== 日志 =====
*.log
npm-debug.log*

# ===== 编辑器 =====
.vscode/
.idea/
*.swp
*.swo
